<confdir:alsa.conf>

pcm.dmixer {
    type dmix
    ipc_key 1024
    ipc_perm 0666
    slave {
        pcm "hw:2,0"
        rate 48000
        period_size 1024   # or try 512 / 2048
        buffer_size 8192   # larger buffer helps prevent underruns
    }
    bindings {
        0 0
        1 1
    }
}

pcm.!default {
    type plug
    slave.pcm "dmixer"
}
